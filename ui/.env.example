# Agentic Shadow-Cap — Dashboard Configuration
# Copy to .env and adjust values as needed.

# ── Network Mode ──────────────────────────────────────────────────────────────
# Controls UI behavior and display labels.
# Values: local | devnet | testnet | mainnet
VITE_CANTON_NETWORK_MODE=local

# ── Ledger API ───────────────────────────────────────────────────────────────
# For local Docker: http://localhost:7575
# For devnet/Canton: http://localhost:8081
# For public demo: http://localhost:8080/ledger
VITE_JSON_API_URL=http://localhost:7575

# ── Market Event API ─────────────────────────────────────────────────────────
# For local Docker: http://localhost:8090
# For public demo: http://localhost:8080/market
VITE_MARKET_API_URL=http://localhost:8090

# ── Polling ──────────────────────────────────────────────────────────────────
VITE_POLL_INTERVAL_MS=3000

# ── Authentication ───────────────────────────────────────────────────────────
# true for local/sandbox, false for gateway-authenticated setups
VITE_JSON_API_USE_INSECURE_TOKEN=true

# Static token (if using gateway-provided auth)
# VITE_JSON_API_TOKEN=

# ── Package ID (optional — auto-detected if not set) ─────────────────────────
# VITE_PACKAGE_ID=
