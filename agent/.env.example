# Agentic Shadow-Cap — Agent Configuration
# Copy to .env and adjust values as needed.

# Canton participant ledger API endpoint
DAML_LEDGER_HOST=localhost
DAML_LEDGER_PORT=5011

# OpenAI API key (optional — agents degrade to rule-based logic without it)
OPENAI_API_KEY=sk-your-key-here

# Path to the market volatility feed (JSON or CSV)
MARKET_FEED_PATH=agent/mock_market_feed.json

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Seller Agent ---
DAML_LEDGER_URL=http://localhost:5011
SELLER_AGENT_PARTY=SellerAgent
TRADE_INTENT_TEMPLATE=AgenticShadowCap.Market:TradeIntent
DISCOVERY_TEMPLATE=AgenticShadowCap.Market:DiscoveryInterest
NEGOTIATION_TEMPLATE=AgenticShadowCap.Market:PrivateNegotiation
AGENT_POLL_SECONDS=5
MIN_TICK_CHANGE=0.01
SELLER_DISCOVERY_STRATEGY=SELL_WHISPER
SELLER_COUNTER_MARKUP=1.00

# --- Buyer Agent ---
# DAML_LEDGER_URL=http://localhost:5021
# BUYER_AGENT_PARTY=BuyerAgent
# BUYER_PARTY=Buyer
# TARGET_INSTRUMENT=COMPANY-SERIES-A
# BUYER_MAX_PRICE=110.00
# BUYER_DEFAULT_QTY=1000.00
# BUYER_DISCOVERY_STRATEGY=BUY_WHISPER
