# Agentic Shadow-Cap — Agent Configuration
# Copy to .env and adjust values as needed.

# ── Network Mode ──────────────────────────────────────────────────────────────
# Controls auth requirements and defaults.
# Values: local | devnet | testnet | mainnet
# - local:   insecure tokens allowed, defaults to localhost endpoints
# - devnet:  insecure tokens allowed, Canton L1 LocalNet endpoints
# - testnet: tokens REQUIRED, fails fast if missing
# - mainnet: tokens REQUIRED, fails fast if missing
CANTON_NETWORK_MODE=local

# ── Canton Participant Endpoints (for devnet/testnet/mainnet) ─────────────────
# CANTON_PROVIDER_URL=http://127.0.0.1:3975
# CANTON_USER_URL=http://127.0.0.1:2975
# CANTON_PROVIDER_TOKEN=
# CANTON_USER_TOKEN=
# CANTON_JWT_TOKEN=

# ── Ledger Connection ─────────────────────────────────────────────────────────
# gRPC endpoint (dazl mode, used in local Docker setup)
DAML_LEDGER_URL=http://localhost:5011

# Connection mode: dazl (gRPC) or http-json (v1 gateway)
DAML_LEDGER_MODE=dazl

# v1 gateway endpoint (used with http-json mode / devnet / testnet)
# DAML_HTTP_JSON_URL=http://localhost:8081
# DAML_HTTP_JSON_TOKEN=

# ── OpenAI (optional — agents degrade to rule-based logic without it) ────────
OPENAI_API_KEY=sk-your-key-here

# ── Market Feed ──────────────────────────────────────────────────────────────
MARKET_FEED_PATH=agent/mock_market_feed.json
AGENT_CONTROL_PATH=agent/agent_controls.json

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Party Aliases (configurable for any environment) ─────────────────────────
SELLER_PARTY=Seller
SELLER_AGENT_PARTY=SellerAgent
BUYER_PARTY=Buyer
BUYER_AGENT_PARTY=BuyerAgent
ISSUER_PARTY=Company

# ── Instrument & Seed Defaults ───────────────────────────────────────────────
DEMO_INSTRUMENT=COMPANY-SERIES-A
DEMO_CURRENCY=USD
DEMO_ASSET_QTY=5000.0
DEMO_CASH_AMOUNT=500000.0
DEMO_INTENT_QTY=1500.0
DEMO_INTENT_MIN_PRICE=95.0

# ── Seller Agent ─────────────────────────────────────────────────────────────
TRADE_INTENT_TEMPLATE=AgenticShadowCap.Market:TradeIntent
DISCOVERY_TEMPLATE=AgenticShadowCap.Market:DiscoveryInterest
NEGOTIATION_TEMPLATE=AgenticShadowCap.Market:PrivateNegotiation
AGENT_POLL_SECONDS=5
MIN_TICK_CHANGE=0.01
SELLER_DISCOVERY_STRATEGY=SELL_WHISPER
SELLER_COUNTER_MARKUP=1.00

# ── Buyer Agent ──────────────────────────────────────────────────────────────
TARGET_INSTRUMENT=COMPANY-SERIES-A
BUYER_MAX_PRICE=110.00
BUYER_DEFAULT_QTY=1000.00
BUYER_DISCOVERY_STRATEGY=BUY_WHISPER
