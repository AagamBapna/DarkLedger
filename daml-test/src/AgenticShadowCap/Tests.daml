-- ============================================================
-- Validation: MatchWith same-side interests (both Sell) fails
-- ============================================================

testMatchSameSideFails : Script ()
testMatchSameSideFails = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  sellInterest1 <- createDiscoveryInterest
    issuer seller sellerAgent [buyerAgent] "COMPANY-SERIES-A" Sell "WHISPER_A" 1
  sellInterest2 <- createDiscoveryInterest
    issuer buyer buyerAgent [sellerAgent] "COMPANY-SERIES-A" Sell "WHISPER_B" 1

  submitMustFail issuer do
    exerciseCmd sellInterest1 MatchWith with counterpartyCid = sellInterest2
  pure ()

-- ============================================================
-- Validation: Self-matching (same postingAgent) fails
-- ============================================================

testSelfMatchingFails : Script ()
testSelfMatchingFails = script do
  (seller, sellerAgent, _buyer, _buyerAgent, issuer) <- setupParties

  sellInterestCid <- createDiscoveryInterest
    issuer seller sellerAgent [] "COMPANY-SERIES-A" Sell "SELF_SELL" 1
  buyInterestCid <- createDiscoveryInterest
    issuer seller sellerAgent [] "COMPANY-SERIES-A" Buy "SELF_BUY" 1

  submitMustFail issuer do
    exerciseCmd sellInterestCid MatchWith with counterpartyCid = buyInterestCid
  pure ()

-- ============================================================
-- Repricing: UpdatePrice changes minPrice
-- ============================================================

testUpdatePriceRepricing : Script ()
testUpdatePriceRepricing = script do
  (seller, sellerAgent, _buyer, _buyerAgent, issuer) <- setupParties

  tradeIntentCid <- submit seller do
    createCmd TradeIntent with
      issuer; seller; sellerAgent
      instrument = "COMPANY-SERIES-A"
      quantity = 1000.0; minPrice = 95.0

  newIntentCid <- submit sellerAgent do
    exerciseCmd tradeIntentCid UpdatePrice with newMinPrice = 102.5

  Some newIntent <- queryContractId sellerAgent newIntentCid
  newIntent.minPrice === 102.5
  newIntent.quantity === 1000.0
  newIntent.instrument === "COMPANY-SERIES-A"
  pure ()

