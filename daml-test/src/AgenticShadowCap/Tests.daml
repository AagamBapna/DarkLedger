-- ============================================================
-- Rejection: RejectBySeller archives negotiation mid-flight
-- ============================================================

testRejectBySellerArchivesNegotiation : Script ()
testRejectBySellerArchivesNegotiation = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1000.0, unitPrice = 100.0
  submit sellerAgent do
    exerciseCmd negotiationCid RejectBySeller
  result <- queryContractId sellerAgent negotiationCid
  result === None
  pure ()

-- ============================================================
-- Rejection: RejectByBuyer archives negotiation
-- ============================================================

testRejectByBuyerArchivesNegotiation : Script ()
testRejectByBuyerArchivesNegotiation = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 500.0, unitPrice = 95.0
  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer
  submit buyerAgent do
    exerciseCmd negotiationCid RejectByBuyer
  result <- queryContractId buyerAgent negotiationCid
  result === None
  pure ()

-- ============================================================
-- StartSettlement before issuer approval fails
-- ============================================================

testStartSettlementBeforeApprovalFails : Script ()
testStartSettlementBeforeApprovalFails = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1000.0, unitPrice = 100.0
  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid AcceptBySeller
  submitMustFail issuer do
    exerciseCmd negotiationCid StartSettlement
  pure ()

-- ============================================================
-- Asset holding split and transfer
-- ============================================================

testAssetSplitAndTransfer : Script ()
testAssetSplitAndTransfer = script do
  (seller, _sellerAgent, buyer, _buyerAgent, issuer) <- setupParties

  assetCid <- submit issuer do
    createCmd AssetHolding with
      owner = seller; issuer
      instrument = "COMPANY-SERIES-A"; quantity = 5000.0

  (splitCid, remainderCid) <- submit seller do
    exerciseCmd assetCid SplitAsset with splitQty = 2000.0

  Some split <- queryContractId seller splitCid
  split.quantity === 2000.0
  Some remainder <- queryContractId seller remainderCid
  remainder.quantity === 3000.0

  _ <- submit issuer do
    exerciseCmd splitCid TransferAsset with newOwner = buyer

  buyerAssets <- query @AssetHolding buyer
  assertMsg "Buyer should hold transferred portion" (not (null buyerAssets))
  pure ()

-- ============================================================
-- New invariant: settlement cannot be finalized twice
-- ============================================================

testSettlementCannotFinalizeTwice : Script ()
testSettlementCannotFinalizeTwice = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 800.0, unitPrice = 99.0
  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer
  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid AcceptBySeller
  negotiationCid <- commitAndRevealTerms sellerAgent buyerAgent negotiationCid "800.0" "99.0"
  negotiationCid <- submit issuer do
    exerciseCmd negotiationCid ApproveMatch
  settlementCid <- submit issuer do
    exerciseCmd negotiationCid StartSettlement
  settledCid <- submit issuer do
    exerciseCmd settlementCid SimpleFinalizeSettlement
  submitMustFail issuer do
    exerciseCmd settledCid SimpleFinalizeSettlement
  pure ()

-- ============================================================
-- New invariant: outsider sees zero across private templates
-- ============================================================

testOutsiderSeesZeroAcrossPrivateTemplates : Script ()
testOutsiderSeesZeroAcrossPrivateTemplates = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  outsider <- allocatePartyByHint (PartyIdHint "Outsider")

  _ <- submit seller do
    createCmd TradeIntent with
      issuer; seller; sellerAgent
      instrument = "COMPANY-SERIES-A"
      quantity = 300.0; minPrice = 88.0

  _ <- createDiscoveryInterest
    issuer seller sellerAgent [buyerAgent] "COMPANY-SERIES-A" Sell "OUTSIDER_CHECK" 1

  -- Keep one active negotiation visible to business parties.
  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  _ <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 250.0, unitPrice = 91.0

  -- Also drive one full settlement path so settlement + audit templates are active.
  settlementNegotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"
  settlementNegotiationCid <- submit sellerAgent do
    exerciseCmd settlementNegotiationCid SubmitSellerTerms with qty = 200.0, unitPrice = 92.0
  settlementNegotiationCid <- submit buyerAgent do
    exerciseCmd settlementNegotiationCid AcceptByBuyer
  settlementNegotiationCid <- submit sellerAgent do
    exerciseCmd settlementNegotiationCid AcceptBySeller
  settlementNegotiationCid <- commitAndRevealTerms sellerAgent buyerAgent settlementNegotiationCid "200.0" "92.0"
  settlementNegotiationCid <- submit issuer do
    exerciseCmd settlementNegotiationCid ApproveMatch
  settlementCid <- submit issuer do
    exerciseCmd settlementNegotiationCid StartSettlement
  _ <- submit issuer do
    exerciseCmd settlementCid SimpleFinalizeSettlement

  _ <- submit sellerAgent do
    createCmd AgentDecisionLog with
      agent = sellerAgent
      owner = seller
      instrument = "COMPANY-SERIES-A"
      decision = "outsider-proof-check"
      reasoning = "private on-ledger policy decision"
      timestamp = "2026-02-20T00:00:00Z"
      marketContext = "synthetic-test"

  tradeIntents <- query @TradeIntent outsider
  discoveries <- query @DiscoveryInterest outsider
  negotiations <- query @PrivateNegotiation outsider
  settlements <- query @TradeSettlement outsider
  audits <- query @TradeAuditRecord outsider
  assets <- query @AssetHolding outsider
  cash <- query @CashHolding outsider
  decisions <- query @AgentDecisionLog outsider

  length tradeIntents === 0
  length discoveries === 0
  length negotiations === 0
  length settlements === 0
  length audits === 0
  length assets === 0
  length cash === 0
  length decisions === 0
  pure ()

-- ============================================================
-- New invariant: expired discovery cannot be matched
-- ============================================================

testExpiredDiscoveryCannotBeMatched : Script ()
testExpiredDiscoveryCannotBeMatched = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  now <- getTime
  expiredSellCid <- submit sellerAgent do
    createCmd DiscoveryInterest with
      issuer
      owner = seller
      postingAgent = sellerAgent
      discoverableBy = [buyerAgent]
      instrument = "COMPANY-SERIES-A"
      side = Sell
      strategyTag = "EXPIRED_SELL"
      createdAt = addRelTime now (hours (-2))
      expiresAt = addRelTime now (hours (-1))

  activeBuyCid <- submit buyerAgent do
    createCmd DiscoveryInterest with
      issuer
      owner = buyer
      postingAgent = buyerAgent
      discoverableBy = [sellerAgent]
      instrument = "COMPANY-SERIES-A"
      side = Buy
      strategyTag = "ACTIVE_BUY"
      createdAt = now
      expiresAt = addRelTime now (hours 1)

  submitMustFail issuer do
    exerciseCmd expiredSellCid MatchWith with counterpartyCid = activeBuyCid
  pure ()
