-- ============================================================
-- Validation: ApproveMatch before both sides accept fails
-- ============================================================

testApproveMatchBeforeBothAcceptFails : Script ()
testApproveMatchBeforeBothAcceptFails = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 500.0, unitPrice = 100.0

  submitMustFail issuer do
    exerciseCmd negotiationCid ApproveMatch

  pure ()

