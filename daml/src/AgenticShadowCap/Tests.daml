module AgenticShadowCap.Tests where

import Daml.Script
import DA.Assert ((===))

import AgenticShadowCap.Market

type Parties = (Party, Party, Party, Party, Party)

setupParties : Script Parties
setupParties = do
  seller <- allocatePartyWithHint "Seller" (PartyIdHint "Seller")
  sellerAgent <- allocatePartyWithHint "SellerAgent" (PartyIdHint "SellerAgent")
  buyer <- allocatePartyWithHint "Buyer" (PartyIdHint "Buyer")
  buyerAgent <- allocatePartyWithHint "BuyerAgent" (PartyIdHint "BuyerAgent")
  issuer <- allocatePartyWithHint "Company" (PartyIdHint "Company")
  pure (seller, sellerAgent, buyer, buyerAgent, issuer)

createMatchedNegotiation : Party -> Party -> Party -> Party -> Party -> Text -> Script (ContractId PrivateNegotiation)
createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer instrument = do
  sellInterestCid <- submit sellerAgent do
    createCmd DiscoveryInterest with
      issuer; owner = seller; postingAgent = sellerAgent
      discoverableBy = [buyerAgent]
      instrument; side = Sell; strategyTag = "TEST_SELL"

  buyInterestCid <- submit buyerAgent do
    createCmd DiscoveryInterest with
      issuer; owner = buyer; postingAgent = buyerAgent
      discoverableBy = [sellerAgent]
      instrument; side = Buy; strategyTag = "TEST_BUY"

  submit issuer do
    exerciseCmd sellInterestCid MatchWith with counterpartyCid = buyInterestCid

-- ============================================================
-- Happy-path: full lifecycle through SimpleFinalizeSettlement
-- ============================================================

testHappyPathFullLifecycle : Script ()
testHappyPathFullLifecycle = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  _ <- submit seller do
    createCmd TradeIntent with
      issuer; seller; sellerAgent
      instrument = "COMPANY-SERIES-A"
      quantity = 1500.0
      minPrice = 95.0

  sellInterestCid <- submit sellerAgent do
    createCmd DiscoveryInterest with
      issuer; owner = seller; postingAgent = sellerAgent
      discoverableBy = [buyerAgent]
      instrument = "COMPANY-SERIES-A"; side = Sell
      strategyTag = "PASSIVE_LIQUIDITY"

  buyInterestCid <- submit buyerAgent do
    createCmd DiscoveryInterest with
      issuer; owner = buyer; postingAgent = buyerAgent
      discoverableBy = [sellerAgent]
      instrument = "COMPANY-SERIES-A"; side = Buy
      strategyTag = "ROFR_ELIGIBLE"

  negotiationCid <- submit issuer do
    exerciseCmd sellInterestCid MatchWith with counterpartyCid = buyInterestCid

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1200.0, unitPrice = 101.5

  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid AcceptBySeller

  negotiationCid <- submit issuer do
    exerciseCmd negotiationCid ApproveMatch

  settlementCid <- submit issuer do
    exerciseCmd negotiationCid StartSettlement

  _ <- submit issuer do
    exerciseCmd settlementCid SimpleFinalizeSettlement

  audits <- query @TradeAuditRecord issuer
  length audits === 1

  pure ()

-- ============================================================
-- Happy-path: full DvP with AssetHolding / CashHolding transfer
-- ============================================================

testHappyPathWithDvP : Script ()
testHappyPathWithDvP = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  assetCid <- submit issuer do
    createCmd AssetHolding with
      owner = seller; issuer
      instrument = "COMPANY-SERIES-A"; quantity = 2000.0

  cashCid <- submit issuer do
    createCmd CashHolding with
      owner = buyer; issuer
      currency = "USD"; amount = 200000.0

  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1000.0, unitPrice = 100.0

  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid AcceptBySeller

  negotiationCid <- submit issuer do
    exerciseCmd negotiationCid ApproveMatch

  settlementCid <- submit issuer do
    exerciseCmd negotiationCid StartSettlement

  _ <- submit issuer do
    exerciseCmd settlementCid FinalizeSettlement with
      sellerAssetCid = assetCid
      buyerCashCid = cashCid

  buyerAssets <- query @AssetHolding buyer
  assertMsg "Buyer should hold transferred asset" (not (null buyerAssets))

  sellerCash <- query @CashHolding seller
  assertMsg "Seller should hold received cash" (not (null sellerCash))

  sellerRemainder <- query @AssetHolding seller
  assertMsg "Seller should hold remainder asset" (not (null sellerRemainder))

  buyerChange <- query @CashHolding buyer
  assertMsg "Buyer should hold change cash" (not (null buyerChange))

  pure ()

-- ============================================================
-- Privacy: TradeIntent is invisible to Buyer / BuyerAgent
-- ============================================================

testTradeIntentInvisibleToBuyer : Script ()
testTradeIntentInvisibleToBuyer = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  _ <- submit seller do
    createCmd TradeIntent with
      issuer; seller; sellerAgent
      instrument = "COMPANY-SERIES-A"
      quantity = 500.0; minPrice = 90.0

  buyerView <- query @TradeIntent buyer
  length buyerView === 0

  buyerAgentView <- query @TradeIntent buyerAgent
  length buyerAgentView === 0

  issuerView <- query @TradeIntent issuer
  assertMsg "Issuer should see the TradeIntent" (not (null issuerView))

  pure ()

-- ============================================================
-- Privacy: PrivateNegotiation invisible to unrelated party
-- ============================================================

testNegotiationInvisibleToOutsider : Script ()
testNegotiationInvisibleToOutsider = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties
  outsider <- allocatePartyWithHint "Outsider" (PartyIdHint "Outsider")

  _ <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  outsiderView <- query @PrivateNegotiation outsider
  length outsiderView === 0

  issuerView <- query @PrivateNegotiation issuer
  assertMsg "Issuer should see the negotiation" (not (null issuerView))

  pure ()

-- ============================================================
-- Privacy: Discovery signal visible only to targeted counterparties
-- ============================================================

testDiscoverySignalScopedVisibility : Script ()
testDiscoverySignalScopedVisibility = script do
  (seller, sellerAgent, _buyer, buyerAgent, issuer) <- setupParties
  outsider <- allocatePartyWithHint "Outsider" (PartyIdHint "Outsider")

  _ <- submit sellerAgent do
    createCmd DiscoveryInterest with
      issuer; owner = seller; postingAgent = sellerAgent
      discoverableBy = [buyerAgent]
      instrument = "COMPANY-SERIES-A"; side = Sell
      strategyTag = "TARGETED_SIGNAL"

  buyerAgentView <- query @DiscoveryInterest buyerAgent
  length buyerAgentView === 1

  outsiderView <- query @DiscoveryInterest outsider
  length outsiderView === 0

  pure ()

