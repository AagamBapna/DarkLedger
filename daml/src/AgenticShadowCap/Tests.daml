-- ============================================================
-- Rejection: RejectBySeller archives negotiation mid-flight
-- ============================================================

testRejectBySellerArchivesNegotiation : Script ()
testRejectBySellerArchivesNegotiation = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1000.0, unitPrice = 100.0

  submit sellerAgent do
    exerciseCmd negotiationCid RejectBySeller

  result <- queryContractId sellerAgent negotiationCid
  result === None

  pure ()

-- ============================================================
-- Rejection: RejectByBuyer archives negotiation
-- ============================================================

testRejectByBuyerArchivesNegotiation : Script ()
testRejectByBuyerArchivesNegotiation = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 500.0, unitPrice = 95.0

  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer

  submit buyerAgent do
    exerciseCmd negotiationCid RejectByBuyer

  result <- queryContractId buyerAgent negotiationCid
  result === None

  pure ()

-- ============================================================
-- StartSettlement before issuer approval fails
-- ============================================================

testStartSettlementBeforeApprovalFails : Script ()
testStartSettlementBeforeApprovalFails = script do
  (seller, sellerAgent, buyer, buyerAgent, issuer) <- setupParties

  negotiationCid <- createMatchedNegotiation seller sellerAgent buyer buyerAgent issuer "COMPANY-SERIES-A"

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid SubmitSellerTerms with qty = 1000.0, unitPrice = 100.0

  negotiationCid <- submit buyerAgent do
    exerciseCmd negotiationCid AcceptByBuyer

  negotiationCid <- submit sellerAgent do
    exerciseCmd negotiationCid AcceptBySeller

  submitMustFail issuer do
    exerciseCmd negotiationCid StartSettlement

  pure ()

-- ============================================================
-- Asset holding split and transfer
-- ============================================================

testAssetSplitAndTransfer : Script ()
testAssetSplitAndTransfer = script do
  (seller, _sellerAgent, buyer, _buyerAgent, issuer) <- setupParties

  assetCid <- submit issuer do
    createCmd AssetHolding with
      owner = seller; issuer
      instrument = "COMPANY-SERIES-A"; quantity = 5000.0

  (splitCid, remainderCid) <- submit seller do
    exerciseCmd assetCid SplitAsset with splitQty = 2000.0

  Some split <- queryContractId seller splitCid
  split.quantity === 2000.0

  Some remainder <- queryContractId seller remainderCid
  remainder.quantity === 3000.0

  _ <- submit issuer do
    exerciseCmd splitCid TransferAsset with newOwner = buyer

  buyerAssets <- query @AssetHolding buyer
  assertMsg "Buyer should hold transferred portion" (not (null buyerAssets))

  pure ()
